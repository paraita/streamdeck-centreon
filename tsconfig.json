{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"types": ["node"],
		"declaration": false,
		"strict": true,
		"esModuleInterop": true,
		"outDir": "./com.io.paraita.centreon.alerts.sdPlugin/bin",
		"rootDir": "./src",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*.ts"]
}
